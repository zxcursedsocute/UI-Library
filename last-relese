		local function updateValue(newValue)
			value = math.clamp(newValue, minVal, maxVal)

			local range = maxVal - minVal
			local percent = (range > 0) and ((value - minVal) / range) or 0

			underline.Size = ud2(percent, 0, 0, 2)
			sliderball.Position = ud2(percent, 0, 0.5, 0)

			local displayValue = (maxVal > 10) and math.floor(value + 0.5) or (math.floor(value * 10 + 0.5) / 10)
			slideramount.Text = (maxVal > 10) and tostring(displayValue) or string.format("%.1f", displayValue)

			if config.Callback then
				task.spawn(config.Callback, displayValue)
			end
		end

		local function moveSlider(input)
			local pos = input.Position.X - sliderbutton.AbsolutePosition.X
			local percent = math.clamp(pos / sliderbutton.AbsoluteSize.X, 0, 1)
			updateValue(minVal + percent * (maxVal - minVal))
		end

		sliderbutton.InputBegan:Connect(function(input)
			if input.UserInputType == enum.UserInputType.MouseButton1 or input.UserInputType == enum.UserInputType.Touch then
				Library.IsInteractingWithUI = true
				Library.SharedSliderState.ActiveMoveFunc = moveSlider
				moveSlider(input)
			end
		end)

		local sliderObj = {
			Elem = slider,
			Name = config.Name,
			Value = value,
			GetState = function() return value end,
			SetValue = updateValue
		}

