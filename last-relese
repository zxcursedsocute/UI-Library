		else
			self:AddThemeObject(Paragraph, "BackgroundColor3", "BackGroundElemCol")
			self:AddThemeObject(Paragraph, "BackgroundTransparency", "BackGroundElemTran")
		end
		Paragraph.BorderSizePixel = 0

		UICorner.CornerRadius = ud(0, 12)
