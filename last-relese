		ContentLabel.TextWrapped = true
		ContentLabel.TextXAlignment = enum.TextXAlignment.Left
		ContentLabel.TextYAlignment = enum.TextYAlignment.Top
		ContentLabel.Parent = Paragraph

		Paragraph.Parent = self.Container

		local function recalcSizes()
			local contentText = ContentLabel.Text
			local hasSubtitle = contentText ~= "" and contentText ~= nil

			if hasSubtitle then
				local textSizeVec = TextService:GetTextSize(contentText, ContentLabel.TextSize, ContentLabel.Font, Vector2.new(328, 10000))
				local contentHeight = math.max(16, math.ceil(textSizeVec.Y))

				ContentLabel.Visible = true
				ContentLabel.Position = ud2(0.027, 0, 0, 28)
				ContentLabel.Size = ud2(0, 328, 0, contentHeight + 4)

				TitleLabel.Position = ud2(0.027, 0, 0, 5)
				Paragraph.Size = ud2(0, 360, 0, 33 + contentHeight)
			else
				ContentLabel.Visible = false
				Paragraph.Size = ud2(0, 360, 0, 40)
				TitleLabel.Position = ud2(0.027, 0, 0, 10)
			end
		end

		recalcSizes()

		local paragraphObj = {
			Element = Paragraph,
			Elem = Paragraph,
			Update = function(objSelf, newTitle, newSubtitle)
				if not objSelf.Element then return end

				if newTitle then TitleLabel.Text = newTitle end
				if newSubtitle ~= nil then ContentLabel.Text = newSubtitle end

				recalcSizes()
			end,
			Destroy = function(objSelf)
				if objSelf.Element then
					objSelf.Element:Destroy()
					objSelf.Element = nil
				end
			end
		}

		return paragraphObj
	end

