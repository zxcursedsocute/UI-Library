		local function updateDropdownPosition()
			if not SharedContainer.Visible then return end
			local absolutePos = Select.AbsolutePosition
			local containerPos = guiRoot.AbsolutePosition

			local currentScale = 1
			local ancestor = guiRoot
			while ancestor and not ancestor:IsA("ScreenGui") do
				local uiScale = ancestor:FindFirstChildWhichIsA("UIScale")
				if uiScale then currentScale *= uiScale.Scale end
				ancestor = ancestor.Parent
			end

			local x = (absolutePos.X - containerPos.X) / currentScale - 4
			local y = (absolutePos.Y - containerPos.Y + Select.AbsoluteSize.Y) / currentScale
			SharedContainer.Position = ud2(0, x, 0, y)
		end

		local function openDropdown()
			if Library.SharedDropdownState.ActiveCloseFunc and Library.SharedDropdownState.ActiveCloseFunc ~= closeDropdown then
				Library.SharedDropdownState.ActiveCloseFunc()
			end

			Library.SharedDropdownState.ActiveCloseFunc = closeDropdown

			for _, child in pairs(SharedOptions:GetChildren()) do
				if child:IsA("TextButton") then child:Destroy() end
			end
			table.clear(optionElements)

			for _, option in ipairs(dropdownObj.Options) do createOption(option) end

			updateDropdownPosition()
			SharedContainer.Visible = true

			local height = math.min(150, #dropdownObj.Options * 30)
			Library:Tween(SharedContainer, {Size = ud2(0, 140, 0, height + 10)}, 0.2)
			Library:Tween(SharedOptions, {Size = ud2(0, 135, 0, height)}, 0.2)
			refreshVisuals()

			task.spawn(function()
				while SharedContainer.Visible and Library.SharedDropdownState.ActiveCloseFunc == closeDropdown do
					updateDropdownPosition()
					task.wait()
				end
			end)

			if Library.SharedDropdownState.ClickConnection then Library.SharedDropdownState.ClickConnection:Disconnect() end
			Library.SharedDropdownState.ClickConnection = UserInputService.InputBegan:Connect(function(input)
				if input.UserInputType == enum.UserInputType.MouseButton1 or input.UserInputType == enum.UserInputType.Touch then
					local pos = input.Position
					local inSelect = pos.X >= Select.AbsolutePosition.X and pos.X <= Select.AbsolutePosition.X + Select.AbsoluteSize.X and pos.Y >= Select.AbsolutePosition.Y and pos.Y <= Select.AbsolutePosition.Y + Select.AbsoluteSize.Y
					local inOptions = pos.X >= SharedContainer.AbsolutePosition.X and pos.X <= SharedContainer.AbsolutePosition.X + SharedContainer.AbsoluteSize.X and pos.Y >= SharedContainer.AbsolutePosition.Y and pos.Y <= SharedContainer.AbsolutePosition.Y + SharedContainer.AbsoluteSize.Y

					if not inSelect and not inOptions then closeDropdown() end
				end
			end)
		end

		Select.MouseButton1Click:Connect(function()
			if SharedContainer.Visible and Library.SharedDropdownState.ActiveCloseFunc == closeDropdown then 
				closeDropdown() 
			else 
				openDropdown() 
			end
		end)

		dropdownObj.GetValue = function(self) return self.Selected end

		dropdownObj.SetValue = function(self, value)
			if self.Multi then
				table.clear(self.Selected)
				if type(value) == "table" then
					for option, selected in pairs(value) do
						if selected and table.find(self.Options, option) then self.Selected[option] = true end
					end
				end
				local selectedText = ""
				for opt, sel in pairs(self.Selected) do
					if sel then selectedText = selectedText .. (selectedText == "" and opt or ", " .. opt) end
				end
				TextLabel.Text = selectedText == "" and "Select..." or selectedText
			else
				if table.find(self.Options, value) then
					self.Selected = value
					TextLabel.Text = value
				else
					TextLabel.Text = "Select..."
				end
			end
			if Library.SharedDropdownState.ActiveCloseFunc == closeDropdown then refreshVisuals() end
			if self.Callback then self.Callback(self.Selected) end
		end

		dropdownObj.UpdateOptions = function(self, newOptions, newDefault)
			self.Options = newOptions
			if SharedContainer.Visible and Library.SharedDropdownState.ActiveCloseFunc == closeDropdown then
				openDropdown()
			end
			self:SetValue(newDefault or (self.Multi and {} or nil))
		end

		dropdownObj.SetVisible = function(self, visible) Dropdown.Visible = visible end

		dropdownObj.Destroy = function(self)
			if Library.SharedDropdownState.ActiveCloseFunc == closeDropdown then closeDropdown() end
			Dropdown:Destroy()
		end

		if config.Default then dropdownObj:SetValue(config.Default) end
		self.AllElements.Dropdowns[config.Name] = dropdownObj

		return dropdownObj
	end

