	if self.Destroy_gui then
		self.Destroy_gui.Visible = false
	end
	self.AllElements.Toggles = {}
	self.ThemeObjects = {}

	local tweenInfo = TweenInfo.new(0.8, enum.EasingStyle.Quad, enum.EasingDirection.Out)
