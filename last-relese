function Library:AddThemeObject(instance : Instance, property : string, themeKey : string)
	if not self.ThemeObjects then 
		self.ThemeObjects = setmetatable({}, {__mode = "k"}) 
	end

	if not self.ThemeObjects[instance] then
		self.ThemeObjects[instance] = {}
	end

	table.insert(self.ThemeObjects[instance], {Property = property, ThemeKey = themeKey})

	if self.Theme and self.Theme[themeKey] ~= nil then
		instance[property] = self.Theme[themeKey]
	end
end

function Library:BuildKeySystem(config, callback)
	if config.SaveKey and isfile and readfile then
		local fileName = config.KeyFileName or "SavedHubKey.txt"
		if isfile(fileName) then
			local savedKey = string.gsub(readfile(fileName), "^%s*(.-)%s*$", "%1")
			local valid = false

			for _, k in pairs(config.Keys or {}) do
				if savedKey == k then valid = true break end
			end

