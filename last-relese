	self.CurrentThemeName = config.Theme or "Cursed"
	self.Theme = extendTheme(Themes[self.CurrentThemeName], {})

	if config.Key then
		local KeyWait = inst("BindableEvent")
		self:BuildKeySystem(config.KeySettings or {}, function()
			KeyWait:Fire()
		end)
		KeyWait.Event:Wait()
	end

	self.mainTabs = {}
	self.CurrentTab = nil
	self.Notipos = 0.9
	self.ThemeObjects = {}

	self.AllElements = {
		Toggles = {},
		Keybinds = {},
		Dropdowns = {},
		Sliders = {},
		ColorPickers = {},
		Inputs = {}
	}
	self.Windowscd = false
	self.userinfo = true
	self.saveFolder = nil
	self.saveFileName = nil
	self.ActiveNotifications = {}

	self.UI = inst("ScreenGui")
	self.UI.ZIndexBehavior = enum.ZIndexBehavior.Sibling
	self.UI.Parent = gethui and gethui() or (CoreGui or LocalPlayer:WaitForChild("PlayerGui"))

	self.ImageLabel = inst("ImageLabel")
	self.ImageLabel.BackgroundColor3 = c3rgb(255, 255, 255)
	self.ImageLabel.BackgroundTransparency = 1
	self.ImageLabel.BorderColor3 = c3rgb(0, 0, 0)
	self.ImageLabel.BorderSizePixel = 0
	self.ImageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	self.ImageLabel.Position = ud2(0.5, 0, 0.5, 0)
	self.ImageLabel.Size = ud2(0,10,0,10)

	self.ScaleFactor = 1

	if UserInputService.touchEnabled then
		local uiScale = inst("UIScale")
		uiScale.Scale = 0.75
		uiScale.Parent = self.ImageLabel

		self.ScaleFactor = 0.75
	end

	self:AddThemeObject(self.ImageLabel, "Image", "BackGroundIcon")
	self.ImageLabel.Active = true
	self.ImageLabel.ImageTransparency = 0.05
	self.ImageLabel.Parent = self.UI

	local dragging = false
	local dragInput = nil
	local dragStart = Vector3.new()
	local startPos = ud2(0, 0, 0, 0)

	self.ImageLabel.InputBegan:Connect(function(input)
		if input.UserInputType == enum.UserInputType.MouseButton1 or input.UserInputType == enum.UserInputType.Touch then
			if Library.IsInteractingWithUI then
				Library.IsInteractingWithUI = false 
				return 
			end

			dragging = true
			dragInput = input
			dragStart = input.Position
			startPos = self.ImageLabel.Position

			local connection
			connection = input.Changed:Connect(function()
				if input.UserInputState == enum.UserInputState.End then
					dragging = false
					dragInput = nil
					if connection then
						connection:Disconnect()
					end
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging then
			local isTouch = (input == dragInput)
			local isMouse = (dragInput.UserInputType == enum.UserInputType.MouseButton1 and input.UserInputType == enum.UserInputType.MouseMovement)

			if isTouch or isMouse then
				local delta = input.Position - dragStart
				local scale = self.ScaleFactor or 1

				self.ImageLabel.Position = ud2(
					startPos.X.Scale, 
					startPos.X.Offset + (delta.X / scale), 
					startPos.Y.Scale, 
					startPos.Y.Offset + (delta.Y / scale)
				)
			end
		end
	end)

	self.Header = inst("Frame")
	self:AddThemeObject(self.Header, "BackgroundColor3", "HeaderColor")
	self.Header.BackgroundTransparency = 1
