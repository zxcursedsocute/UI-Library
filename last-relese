		end

		TitleLabel.TextSize = 16
		TitleLabel.TextXAlignment = enum.TextXAlignment.Left
		TitleLabel.Parent = Paragraph

		ContentLabel.BackgroundTransparency = 1
		ContentLabel.Font = enum.Font.FredokaOne
