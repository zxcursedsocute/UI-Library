		local optionElements = {}

		local function formatTextWrap(str, wrapLimit, maxLimit)
			if not str or str == "" then return "Select..." end
			local visible_count = 0
			for i = 1, #str do
				local c = str:sub(i, i)
				if c ~= " " and c ~= "," then visible_count = visible_count + 1 end
				if visible_count >= wrapLimit then
					local break_pos = i
					for j = i + 1, #str do
						local next_char = str:sub(j, j)
						if next_char ~= " " and next_char ~= "," then break end
						break_pos = j
					end
					local result = str
					if #result >= maxLimit then result = result:sub(1, maxLimit) .. "..." end
					return result:sub(1, break_pos) .. "\n" .. result:sub(break_pos + 1)
				end
			end
			if #str >= maxLimit then return str:sub(1, maxLimit) .. "..." end
			return str
		end

		local function refreshVisuals()
			for optText, frameInd in pairs(optionElements) do
				local isSelected = dropdown.Multi and dropdown.Selected[optText] or (dropdown.Selected == optText)
				if isSelected then
					Library:Tween(frameInd, {Size = UDim2.new(0, 2, 0, 22), BackgroundTransparency = 0}, 0.2)
				else
					Library:Tween(frameInd, {Size = UDim2.new(0, 2, 0, 0), BackgroundTransparency = 1}, 0.2)
				end
			end
		end

		local function closeDropdown()
			if not SharedContainer.Visible then return end
			Library:Tween(SharedContainer, {Size = UDim2.new(0, 140, 0, 0)}, 0.2)
			Library:Tween(SharedOptions, {Size = UDim2.new(0, 135, 0, 0)}, 0.2)

			if Library.SharedDropdownState.ClickConnection then 
				Library.SharedDropdownState.ClickConnection:Disconnect() 
				Library.SharedDropdownState.ClickConnection = nil 
			end

			task.delay(0.2, function()
				if Library.SharedDropdownState.ActiveCloseFunc == closeDropdown then
					SharedContainer.Visible = false
					table.clear(optionElements)
				end
			end)
		end

		local function handleOptionClick(option)
			if dropdown.Multi then
				dropdown.Selected[option] = not dropdown.Selected[option]

				local selectedText = ""
				for opt, sel in pairs(dropdown.Selected) do
					if sel then selectedText = selectedText .. (selectedText == "" and opt or "," .. opt) end
				end
				TextLabel.Text = formatTextWrap(selectedText, 14, 28)
				refreshVisuals()
			else
				TextLabel.Text = formatTextWrap(option, 14, 28)
				dropdown.Selected = option
				refreshVisuals()
				closeDropdown()
			end

			if type(dropdown.Callback) == "function" then
				task.spawn(function()
					local success, err = pcall(dropdown.Callback, dropdown.Multi and dropdown.Selected or option)
				end)
			end
		end

		local function createOption(optionText)
			local Option = Instance.new("TextButton")
