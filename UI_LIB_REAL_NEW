		local BlacklistedKeys = {
			[Enum.KeyCode.Unknown] = true, [Enum.KeyCode.W] = true,
			[Enum.KeyCode.A] = true, [Enum.KeyCode.S] = true,
			[Enum.KeyCode.D] = true, [Enum.KeyCode.Escape] = true,
			[Enum.KeyCode.Space] = true, [Enum.KeyCode.Backspace] = true
		}

		local selectConnection
		selectConnection = bindButton.MouseButton1Click:Connect(function()
			bindButton.Text = "..."
			local connection

			connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
				task.wait()
				if gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then return end

				if input.UserInputType == Enum.UserInputType.Keyboard then
					if not BlacklistedKeys[input.KeyCode] then
						setKey(input.KeyCode)
					else
						setKey(nil)
					end
					connection:Disconnect()
				elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
					setKey(nil)
					connection:Disconnect()
				end
			end)
		end)
		table.insert(tab.Connections, selectConnection)

		if not self.AllElements.GlobalKeybindConnection then
			self.AllElements.GlobalKeybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
				if gameProcessed then return end

				if input.UserInputType == Enum.UserInputType.Keyboard then
					for _, kbObj in pairs(self.AllElements.Keybinds) do
						local key = kbObj:GetState()
						if key and input.KeyCode == key and kbObj.Callback then
							task.spawn(kbObj.Callback)
						end
					end
				end
			end)
		end

		local keybindObj = {
			Name = Keybind.Name,
			Elem = container,
			SetKey = setKey,
			GetState = function()
				return currentKey
			end,
			Callback = Keybind.Callback
		}

		if self.AllElements and self.AllElements.Keybinds then
			self.AllElements.Keybinds[Keybind.Name] = keybindObj
		end

		return keybindObj
	end

