function Library:AddThemeObject(instance, property, themeKey)
	if not self.ThemeObjects then self.ThemeObjects = {} end
	table.insert(self.ThemeObjects, {Instance = instance, Property = property, ThemeKey = themeKey})

	if self.Theme and self.Theme[themeKey] ~= nil then
		instance[property] = self.Theme[themeKey]
	end
end

