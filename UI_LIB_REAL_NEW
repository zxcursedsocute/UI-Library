function Library:GetAsset(url)
	if not self.ImageCache then self.ImageCache = {} end
	if self.ImageCache[url] then return self.ImageCache[url] end

	local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
	local getcustomasset = getcustomasset or getsynasset

	if not req or not writefile or not getcustomasset then return nil end

	local success, response = pcall(function()
		return req({Url = url, Method = "GET"})
	end)

	if success and response.StatusCode == 200 then
		local fileName = "discord_cache_" .. tick() .. ".png"
		writefile(fileName, response.Body)
		local asset = getcustomasset(fileName)
		self.ImageCache[url] = asset
		return asset
	end
	return nil
end

function Library:SetTheme(themeName : string)
	if self.CurrentThemeName == themeName then return end

	local theme = Themes[themeName]
	if not theme then return end

	self.CurrentThemeName = themeName
	self.Theme = theme

	local aliveObjects = {}
	if self.ThemeObjects then
		for _, obj in ipairs(self.ThemeObjects) do
			if obj.Instance and obj.Instance.Parent then
				obj.Instance[obj.Property] = theme[obj.ThemeKey]
				table.insert(aliveObjects, obj)
			end
		end
		self.ThemeObjects = aliveObjects
	end

	for i, v in pairs(self.ActiveNotifications) do
		v.notification.Image = theme.NotiImg
		v.notification.Title.TextColor3 = theme.TextColor
		v.notification.Description.TextColor3 = theme.SubTtitleTextColor
		v.notification.CloseButton.ImageColor3 = theme.TabsIconColor
		if v.notification.Icon.Image == "rbxassetid://75930996983661" or v.notification.Icon.Image == "rbxassetid://76158273611595" then
			v.notification.Icon.ImageColor3 = theme.TabsIconColor
		end
	end

	if self.AllElements and self.AllElements.Toggles then
		for _, tgl in pairs(self.AllElements.Toggles) do
			tgl:UpdateVisuals(tgl.Value, true)
		end
	end

	if self.CurrentTab and self.CurrentTab.Tab and self.CurrentTab.Tab[1] then
		self.CurrentTab.Tab[1].BackgroundTransparency = theme.TabTransparancy
	end
end

function Library:AddCategory(name)
	local Window = self
	Window.Categories = Window.Categories or {}

	local category = {
		Name = name,
		Tabs = {},
		Header = nil,
		Arrow = nil,
		Container = nil,
		Wrapper = nil
	}

	local CategoryWrapper = Instance.new("Frame")
	CategoryWrapper.BackgroundTransparency = 1
	CategoryWrapper.Size = UDim2.new(0, 173, 0, 0)
	CategoryWrapper.AutomaticSize = Enum.AutomaticSize.Y
	CategoryWrapper.Parent = Window.ScrollingFrame
	category.Wrapper = CategoryWrapper

	local UICorner = Instance.new("UICorner")
	UICorner.CornerRadius = UDim.new(0, 8)
	UICorner.Parent = CategoryWrapper

	local WrapperLayout = Instance.new("UIListLayout")
	WrapperLayout.SortOrder = Enum.SortOrder.LayoutOrder
	WrapperLayout.Parent = CategoryWrapper

	local HeaderBtn = Instance.new("TextButton")
	HeaderBtn.BackgroundTransparency = 1
	HeaderBtn.Size = UDim2.new(0, 173, 0, 30)
	HeaderBtn.Text = ""
	HeaderBtn.Parent = CategoryWrapper

	local HeaderText = Instance.new("TextLabel")
	HeaderText.BackgroundTransparency = 1
	HeaderText.Position = UDim2.new(0.05, 0, 0, 0)
	HeaderText.Size = UDim2.new(0.8, 0, 1, 0)
	HeaderText.Font = Enum.Font.FredokaOne
	HeaderText.Text = name:upper()
	self:AddThemeObject(HeaderText, "TextColor3", "TabTextColor")
	HeaderText.TextSize = 11
	HeaderText.TextXAlignment = Enum.TextXAlignment.Left
	HeaderText.Parent = HeaderBtn
	category.Header = HeaderText

	local Arrow = Instance.new("ImageLabel")
	Arrow.BackgroundTransparency = 1
	Arrow.Position = UDim2.new(0.85, 0, 0.25, 0)
	Arrow.Size = UDim2.new(0, 15, 0, 15)
	Arrow.Image = "rbxassetid://126982255108418" 
	self:AddThemeObject(Arrow, "ImageColor3", "DropDownArrowImg")
	Arrow.Rotation = 0
	Arrow.Parent = HeaderBtn
	category.Arrow = Arrow

	local TabsContainer = Instance.new("Frame")
	self:AddThemeObject(TabsContainer, "BackgroundColor3", "BackGroundElemCol")
	TabsContainer.BackgroundTransparency = 1
	TabsContainer.ClipsDescendants = true
	TabsContainer.Size = UDim2.new(0, 173, 0, 0)
	TabsContainer.Parent = CategoryWrapper
	category.Container = TabsContainer

	local UIListLayout = Instance.new("UIListLayout")
	UIListLayout.Padding = UDim.new(0, 2)
	UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	UIListLayout.Parent = TabsContainer

	local IsOpen = true

	local function GetTargetHeight()
		return (UIListLayout.AbsoluteContentSize.Y / Window.ScaleFactor)
	end

	HeaderBtn.MouseButton1Click:Connect(function()
		IsOpen = not IsOpen
		local targetHeight = IsOpen and GetTargetHeight() or 0
		local targetRotation = IsOpen and 0 or 180

		Window:Tween(Arrow, {Rotation = targetRotation}, 0.2)
		Window:Tween(TabsContainer, {Size = UDim2.new(0, 173, 0, targetHeight)}, 0.3)
	end)

	function category:AddTab(tabName, tabIcon)
		local newTab = Window:AddTab(tabName, tabIcon)
		newTab.Button.Parent = TabsContainer
		newTab.Button.Size = UDim2.new(0, 173, 0, 35)

		if IsOpen then
			TabsContainer.Size = UDim2.new(0, 173, 0, GetTargetHeight())
		end
		table.insert(self.Tabs, newTab)
		return newTab
	end

	table.insert(Window.Categories, category)
	return category
end

return Library
